@model IEnumerable<MVC_GAMEHUB.Models.Usuario>
@{
    ViewData["Title"] = "Usuários";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var adms = Model.Where(u => u.Perfil == "ADM");
    var users = Model.Where(u => u.Perfil != "ADM");
}

<div class="container mt-4">

    <h2 style="color:#c9b8ff; margin-bottom:24px;">Gerenciar Usuários</h2>

    <!-- Cards de resumo -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div style="background:#1a0f2e; border:1px solid #3a2060; border-radius:6px; padding:20px; text-align:center;">
                <div style="color:#a78bfa; font-size:32px; font-weight:800;">@Model.Count()</div>
                <div style="color:#6a5a8a; font-size:12px; margin-top:4px;">Total de Usuários</div>
            </div>
        </div>
        <div class="col-md-3">
            <div style="background:#1a0f2e; border:1px solid #3a2060; border-radius:6px; padding:20px; text-align:center;">
                <div style="color:#ff6b6b; font-size:32px; font-weight:800;">@adms.Count()</div>
                <div style="color:#6a5a8a; font-size:12px; margin-top:4px;">Administradores</div>
            </div>
        </div>
        <div class="col-md-3">
            <div style="background:#1a0f2e; border:1px solid #3a2060; border-radius:6px; padding:20px; text-align:center;">
                <div style="color:#6fcf6f; font-size:32px; font-weight:800;">@users.Count()</div>
                <div style="color:#6a5a8a; font-size:12px; margin-top:4px;">Usuários Comuns</div>
            </div>
        </div>
    </div>

    <!-- Administradores -->
    <div style="margin-bottom:32px;">
        <div style="display:flex; align-items:center; gap:10px; margin-bottom:14px;">
            <span style="background:#3a0a0a; color:#ff6b6b; border:1px solid #7a1a1a; padding:3px 10px; border-radius:20px; font-size:11px; font-weight:700;">ADM</span>
            <span style="color:#c9b8ff; font-size:15px; font-weight:600;">Administradores</span>
        </div>

        @if (!adms.Any())
        {
            <p style="color:#6a5a8a; font-size:13px;">Nenhum administrador cadastrado.</p>
        }
        else
        {
            <div style="background:#1a0f2e; border:1px solid #3a2060; border-radius:6px; overflow:hidden;">
                <table style="width:100%; border-collapse:collapse;">
                    <thead>
                        <tr style="border-bottom:1px solid #3a2060;">
                            <th style="padding:12px 16px; color:#6a5a8a; font-size:11px; text-transform:uppercase; font-weight:600; text-align:left;">Usuário</th>
                            <th style="padding:12px 16px; color:#6a5a8a; font-size:11px; text-transform:uppercase; font-weight:600; text-align:left;">Email</th>
                            <th style="padding:12px 16px; color:#6a5a8a; font-size:11px; text-transform:uppercase; font-weight:600; text-align:left;">CPF</th>
                            <th style="padding:12px 16px; color:#6a5a8a; font-size:11px; text-transform:uppercase; font-weight:600; text-align:left;">Telefone</th>
                            <th style="padding:12px 16px; color:#6a5a8a; font-size:11px; text-transform:uppercase; font-weight:600; text-align:center;">Perfil</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var u in adms)
                        {
                            <tr style="border-bottom:1px solid #1e1040;"
                                onmouseover="this.style.background='#120a24';"
                                onmouseout="this.style.background='transparent';">
                                <td style="padding:12px 16px;">
                                    <div style="display:flex; align-items:center; gap:10px;">
                                        <div style="width:32px; height:32px; border-radius:50%; background:#5c2d91; display:flex; align-items:center; justify-content:center; font-size:13px; font-weight:700; color:#e0d0ff; border:2px solid #7c4dff; flex-shrink:0;">
                                            @u.Nome[0]
                                        </div>
                                        <span style="color:#c9b8ff; font-size:13px; font-weight:600;">@u.Nome</span>
                                    </div>
                                </td>
                                <td style="padding:12px 16px; color:#a89cc8; font-size:13px;">@u.Email</td>
                                <td style="padding:12px 16px; color:#a89cc8; font-size:13px;">@u.Cpf</td>
                                <td style="padding:12px 16px; color:#a89cc8; font-size:13px;">@u.Telefone</td>
                                <td style="padding:12px 16px; text-align:center;">
                                    <span style="background:#3a0a0a; color:#ff6b6b; border:1px solid #7a1a1a; padding:3px 10px; border-radius:20px; font-size:11px; font-weight:700;">ADM</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <!-- Usuários comuns -->
    <div>
        <div style="display:flex; align-items:center; gap:10px; margin-bottom:14px;">
            <span style="background:#0a2a0a; color:#6fcf6f; border:1px solid #1a6a1a; padding:3px 10px; border-radius:20px; font-size:11px; font-weight:700;">USR</span>
            <span style="color:#c9b8ff; font-size:15px; font-weight:600;">Usuários</span>
        </div>

        @if (!users.Any())
        {
            <p style="color:#6a5a8a; font-size:13px;">Nenhum usuário cadastrado.</p>
        }
        else
        {
            <div style="background:#1a0f2e; border:1px solid #3a2060; border-radius:6px; overflow:hidden;">
                <table style="width:100%; border-collapse:collapse;">
                    <thead>
                        <tr style="border-bottom:1px solid #3a2060;">
                            <th style="padding:12px 16px; color:#6a5a8a; font-size:11px; text-transform:uppercase; font-weight:600; text-align:left;">Usuário</th>
                            <th style="padding:12px 16px; color:#6a5a8a; font-size:11px; text-transform:uppercase; font-weight:600; text-align:left;">Email</th>
                            <th style="padding:12px 16px; color:#6a5a8a; font-size:11px; text-transform:uppercase; font-weight:600; text-align:left;">CPF</th>
                            <th style="padding:12px 16px; color:#6a5a8a; font-size:11px; text-transform:uppercase; font-weight:600; text-align:left;">Telefone</th>
                            <th style="padding:12px 16px; color:#6a5a8a; font-size:11px; text-transform:uppercase; font-weight:600; text-align:center;">Perfil</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var u in users)
                        {
                            <tr style="border-bottom:1px solid #1e1040;"
                                onmouseover="this.style.background='#120a24';"
                                onmouseout="this.style.background='transparent';">
                                <td style="padding:12px 16px;">
                                    <div style="display:flex; align-items:center; gap:10px;">
                                        <div style="width:32px; height:32px; border-radius:50%; background:#0a2a0a; display:flex; align-items:center; justify-content:center; font-size:13px; font-weight:700; color:#6fcf6f; border:2px solid #1a6a1a; flex-shrink:0;">
                                            @u.Nome[0]
                                        </div>
                                        <span style="color:#c9b8ff; font-size:13px; font-weight:600;">@u.Nome</span>
                                    </div>
                                </td>
                                <td style="padding:12px 16px; color:#a89cc8; font-size:13px;">@u.Email</td>
                                <td style="padding:12px 16px; color:#a89cc8; font-size:13px;">@u.Cpf</td>
                                <td style="padding:12px 16px; color:#a89cc8; font-size:13px;">@u.Telefone</td>
                                <td style="padding:12px 16px; text-align:center;">
                                    <span style="background:#0a2a0a; color:#6fcf6f; border:1px solid #1a6a1a; padding:3px 10px; border-radius:20px; font-size:11px; font-weight:700;">USR</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

</div>