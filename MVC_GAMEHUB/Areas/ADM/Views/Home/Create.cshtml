@model MVC_GAMEHUB.Models.Jogo
@{
    ViewData["Title"] = "Adicionar Jogo";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4" style="max-width:600px;">
    <h2 style="color:#c9b8ff;">Adicionar Jogo</h2>
    <hr style="border-color:#3a2060;">

    <form asp-action="Create" method="post">
        <div class="mb-3">
            <label asp-for="Nome" style="color:#a89cc8;"></label>
            <input asp-for="Nome" class="form-control" style="background:#1a0f2e; color:#e0d0ff; border-color:#4a2d7a;" />
            <span asp-validation-for="Nome" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Categoria" style="color:#a89cc8;"></label>
            <input asp-for="Categoria" class="form-control" style="background:#1a0f2e; color:#e0d0ff; border-color:#4a2d7a;" />
            <span asp-validation-for="Categoria" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Preco" style="color:#a89cc8;"></label>
            <input asp-for="Preco" class="form-control" style="background:#1a0f2e; color:#e0d0ff; border-color:#4a2d7a;" />
            <span asp-validation-for="Preco" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="ImagemUrl" style="color:#a89cc8;"></label>
            <input asp-for="ImagemUrl" class="form-control" style="background:#1a0f2e; color:#e0d0ff; border-color:#4a2d7a;" placeholder="https://..." />
            <span asp-validation-for="ImagemUrl" class="text-danger"></span>
        </div>

        <div style="display:flex; gap:10px; margin-top:24px;">
            <button type="submit" style="background:#5c2d91; color:#e0d0ff; border:1px solid #7c4dff; padding:8px 24px; border-radius:4px; font-weight:600;">
                Salvar
            </button>
            <a asp-action="Loja" asp-controller="Home" asp-area="ADM"
               style="background:transparent; color:#a89cc8; border:1px solid #4a2d7a; padding:8px 24px; border-radius:4px; text-decoration:none;">
                Cancelar
            </a>
        </div>
    </form>
</div>