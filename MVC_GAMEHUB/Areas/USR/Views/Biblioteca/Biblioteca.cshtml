@model IEnumerable<MVC_GAMEHUB.Models.PedidoItem>
@{
    ViewData["Title"] = "Minha Biblioteca";
    Layout = "~/Views/Shared/_LayoutUser.cshtml";
    var nome = Context.Session.GetString("UsuarioNome") ?? "Usuário";
}

<div class="container mt-4">
    <div class="d-flex align-items-center gap-3 mb-4">
        <h2 style="color:#c9b8ff; margin:0;">Minha Biblioteca</h2>
        <span style="color:#6a5a8a; font-size:14px;">@Model.Count() jogo(s)</span>
    </div>

    @if (!Model.Any())
    {
        <div style="text-align:center; padding:80px 0;">
            <div style="font-size:48px; margin-bottom:16px;">🎮</div>
            <div style="color:#6a5a8a; font-size:16px; margin-bottom:24px;">Você ainda não comprou nenhum jogo.</div>
            <a href="/USR/Jogos/Loja"
               style="background:#5c2d91; color:#e0d0ff; border:1px solid #7c4dff; padding:10px 28px; border-radius:4px; text-decoration:none; font-weight:600;">
                Ir para a Loja
            </a>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-md-3 mb-4">
                    <div style="background:#1a0f2e; border:1px solid #3a2060; border-radius:6px; overflow:hidden; transition:transform 0.2s;"
                         onmouseover="this.style.transform='translateY(-4px)'; this.style.borderColor='#7c4dff';"
                         onmouseout="this.style.transform='translateY(0)'; this.style.borderColor='#3a2060';">
                        <div style="position:relative;">
                            <img src="@(string.IsNullOrEmpty(item.JogoImagemUrl) ? "/images/no-image.jpg" : item.JogoImagemUrl)"
                                 style="width:100%; height:160px; object-fit:cover;" />
                            <div style="position:absolute; top:8px; right:8px; background:#1a3a1a; border:1px solid #2d6b2d; border-radius:20px; padding:3px 8px; font-size:10px; color:#6fcf6f; font-weight:700;">
                                ✓ Comprado
                            </div>
                        </div>
                        <div style="padding:12px;">
                            <div style="color:#c9b8ff; font-size:13px; font-weight:600; margin-bottom:4px;">@item.JogoNome</div>
                            <div style="color:#a78bfa; font-size:12px; font-weight:700; margin-bottom:10px;">R$ @item.Preco.ToString("F2")</div>
                            <button style="width:100%; background:#5c2d91; color:#e0d0ff; border:1px solid #7c4dff; padding:8px; border-radius:4px; font-size:12px; font-weight:600; cursor:pointer;"
                                    onmouseover="this.style.background='#7c4dff';"
                                    onmouseout="this.style.background='#5c2d91';">
                                ▶ Jogar
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>