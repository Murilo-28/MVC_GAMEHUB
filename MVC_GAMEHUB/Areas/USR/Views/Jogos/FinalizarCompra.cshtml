@model MVC_GAMEHUB.Models.Pedido
@{
    ViewData["Title"] = "Compra Concluída";
    Layout = "~/Views/Shared/_LayoutUser.cshtml";
}

<div class="container mt-4" style="max-width:560px;">
    <div style="text-align:center; padding:40px 0 32px;">
        <div style="font-size:64px; margin-bottom:16px;">✅</div>
        <h2 style="color:#c9b8ff; margin-bottom:8px;">Compra Concluída!</h2>
        <p style="color:#a89cc8;">
            Obrigado, <strong style="color:#c9b8ff;">@Model.UsuarioNome</strong>!
            Seus jogos já estão disponíveis na sua biblioteca.
        </p>
    </div>

    <div style="background:#1a0f2e; border:1px solid #3a2060; border-radius:6px; padding:20px; margin-bottom:24px;">
        <div style="color:#c9b8ff; font-size:14px; font-weight:700; margin-bottom:16px; padding-bottom:12px; border-bottom:1px solid #3a2060;">
            Resumo do Pedido #@Model.Id
        </div>

        @foreach (var item in Model.Itens)
        {
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:10px;">
                <div style="display:flex; align-items:center; gap:10px;">
                    <img src="@(string.IsNullOrEmpty(item.JogoImagemUrl) ? "/images/no-image.jpg" : item.JogoImagemUrl)"
                         style="width:48px; height:32px; object-fit:cover; border-radius:3px;" />
                    <span style="color:#c9b8ff; font-size:13px;">@item.JogoNome</span>
                </div>
                <span style="color:#a78bfa; font-size:13px; font-weight:700;">R$ @item.Preco.ToString("F2")</span>
            </div>
        }

        <div style="border-top:1px solid #3a2060; margin-top:16px; padding-top:16px; display:flex; justify-content:space-between;">
            <span style="color:#a89cc8; font-size:13px;">Forma de Pagamento</span>
            <span style="color:#c9b8ff; font-size:13px;">@Model.FormaPagamento.ToUpper()</span>
        </div>
        <div style="display:flex; justify-content:space-between; margin-top:8px;">
            <span style="color:#c9b8ff; font-weight:700;">Total</span>
            <span style="color:#a78bfa; font-size:18px; font-weight:800;">R$ @Model.Total.ToString("F2")</span>
        </div>
    </div>

    <div style="text-align:center;">
        <a href="/USR/Jogos/Loja"
           style="background:#5c2d91; color:#e0d0ff; border:1px solid #7c4dff; padding:12px 36px; border-radius:4px; text-decoration:none; font-weight:700;"
           onmouseover="this.style.background='#7c4dff';"
           onmouseout="this.style.background='#5c2d91';">
            Voltar à Loja
        </a>
    </div>
</div>