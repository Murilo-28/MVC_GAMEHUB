@model MVC_GAMEHUB.Models.Usuario

@{
    ViewData["Title"] = "Login Tela";
    ViewBag.HideMenu = true;
    Layout = "~/Views/Shared/_LayoutLogin.cshtml";
}
<section>
    <div class="tituloCadastro">
        <h1>Cadastro</h1>
    </div>
    <div>
        <form asp-action="TelaDeCadastro" method="post">

            @if (ViewBag.Erro != null)
            {
                <div class="alert alert-danger">@ViewBag.Erro</div>
            }

            <div>
                <label asp-for="Nome"></label>
                <input asp-for="Nome" class="form-control" />
                <span asp-validation-for="Nome" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="Telefone"></label>
                <input asp-for="Telefone" class="form-control" />
                <span asp-validation-for="Telefone" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="Email"></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="Cpf"></label>
                <input asp-for="Cpf" class="form-control"/>
                <span asp-validation-for="Cpf" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="Senha"></label>
                <input asp-for="Senha" class="form-control" type="password" />
                <span asp-validation-for="Senha" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="Perfil">Tipo de conta</label>
                <select asp-for="Perfil" class="form-control">
                    <option value="">   Selecione   </option>
                    <option value="USR"> Usuário</option>
                    <option value="ADM"> Administrador</option>
                </select>
                <span asp-validation-for="Perfil" class="text-danger"></span>
            </div>
            <div>
                <input type="submit" value="Entrar"/>
            </div>
            <div>
                <a asp-action="TelaDeLogin">Já tem uma conta? Faça login</a>
            </div>
        </form>
    </div>
</section>
