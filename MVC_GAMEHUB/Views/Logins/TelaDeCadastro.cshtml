@model MVC_GAMEHUB.Models.Usuario
@{
    ViewData["Title"] = "Cadastro";
    ViewBag.HideMenu = true;
    Layout = "~/Views/Shared/_LayoutLogin.cshtml";
}

<div style="min-height:100vh; background:#0f0f1a; display:flex; align-items:center; justify-content:center;">
    <div style="background:#1a0f2e; border:1px solid #3a2060; border-radius:8px; padding:40px; width:100%; max-width:440px; box-shadow:0 8px 32px rgba(0,0,0,0.5);">

        <h2 style="color:#c9b8ff; font-size:22px; font-weight:700; margin-bottom:28px; text-align:center; letter-spacing:1px;">
            Criar Conta
        </h2>

        @if (ViewBag.Erro != null)
        {
            <div style="background:#2d1a2e; border:1px solid #7c2d2d; color:#ff8a8a; padding:10px 14px; border-radius:4px; margin-bottom:16px; font-size:13px;">
                @ViewBag.Erro
            </div>
        }

        <form asp-action="TelaDeCadastro" method="post">
            <div style="margin-bottom:14px;">
                <label asp-for="Nome" style="color:#a89cc8; font-size:12px; font-weight:600; text-transform:uppercase; letter-spacing:0.6px;"></label>
                <input asp-for="Nome" class="form-control" style="background:#0f0f1a; color:#e0d0ff; border:1px solid #4a2d7a; border-radius:4px; margin-top:4px;" />
                <span asp-validation-for="Nome" class="text-danger" style="font-size:11px;"></span>
            </div>

            <div style="margin-bottom:14px;">
                <label asp-for="Telefone" style="color:#a89cc8; font-size:12px; font-weight:600; text-transform:uppercase; letter-spacing:0.6px;"></label>
                <input asp-for="Telefone" class="form-control" style="background:#0f0f1a; color:#e0d0ff; border:1px solid #4a2d7a; border-radius:4px; margin-top:4px;" />
                <span asp-validation-for="Telefone" class="text-danger" style="font-size:11px;"></span>
            </div>

            <div style="margin-bottom:14px;">
                <label asp-for="Email" style="color:#a89cc8; font-size:12px; font-weight:600; text-transform:uppercase; letter-spacing:0.6px;"></label>
                <input asp-for="Email" class="form-control" style="background:#0f0f1a; color:#e0d0ff; border:1px solid #4a2d7a; border-radius:4px; margin-top:4px;" />
                <span asp-validation-for="Email" class="text-danger" style="font-size:11px;"></span>
            </div>

            <div style="margin-bottom:14px;">
                <label asp-for="Cpf" style="color:#a89cc8; font-size:12px; font-weight:600; text-transform:uppercase; letter-spacing:0.6px;"></label>
                <input asp-for="Cpf" class="form-control" style="background:#0f0f1a; color:#e0d0ff; border:1px solid #4a2d7a; border-radius:4px; margin-top:4px;" />
                <span asp-validation-for="Cpf" class="text-danger" style="font-size:11px;"></span>
            </div>

            <div style="margin-bottom:14px;">
                <label asp-for="Senha" style="color:#a89cc8; font-size:12px; font-weight:600; text-transform:uppercase; letter-spacing:0.6px;"></label>
                <input asp-for="Senha" type="password" class="form-control" style="background:#0f0f1a; color:#e0d0ff; border:1px solid #4a2d7a; border-radius:4px; margin-top:4px;" />
                <span asp-validation-for="Senha" class="text-danger" style="font-size:11px;"></span>
            </div>

            <div style="margin-bottom:24px;">
                <label asp-for="Perfil" style="color:#a89cc8; font-size:12px; font-weight:600; text-transform:uppercase; letter-spacing:0.6px;">Tipo de Conta</label>
                <select asp-for="Perfil" class="form-control" style="background:#0f0f1a; color:#e0d0ff; border:1px solid #4a2d7a; border-radius:4px; margin-top:4px;">
                    <option value="">Selecione</option>
                    <option value="USR">Usuário</option>
                    <option value="ADM">Administrador</option>
                </select>
                <span asp-validation-for="Perfil" class="text-danger" style="font-size:11px;"></span>
            </div>

            <button type="submit" style="width:100%; background:#5c2d91; color:#e0d0ff; border:1px solid #7c4dff; padding:10px; border-radius:4px; font-size:14px; font-weight:700; cursor:pointer; letter-spacing:0.5px;"
                    onmouseover="this.style.background='#7c4dff';"
                    onmouseout="this.style.background='#5c2d91';">
                Criar Conta
            </button>

            <div style="text-align:center; margin-top:18px;">
                <a asp-action="TelaDeLogin" style="color:#7c4dff; font-size:13px; text-decoration:none;"
                   onmouseover="this.style.color='#c9b8ff';"
                   onmouseout="this.style.color='#7c4dff';">
                    Já tem uma conta? Faça login
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/validacao-cadastro.js"></script>
}