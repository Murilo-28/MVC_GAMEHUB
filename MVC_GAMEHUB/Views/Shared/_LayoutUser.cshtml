<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MVC_GAMEHUB</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MVC_GAMEHUB.styles.css" asp-append-version="true" />
</head>
<body style="background:#0f0f1a; color:#c6d4df;">
    <header>
        <nav style="background:#1a0f2e; border-bottom:1px solid #3a2060; padding:0 32px; display:flex; align-items:center; height:56px; box-shadow:0 2px 8px rgba(0,0,0,0.4);">

            <a href="/USR/Jogos/Loja"
               style="color:#c9b8ff; font-size:17px; font-weight:700; text-decoration:none; margin-right:40px; letter-spacing:1px;">
                GAME HUB
            </a>

            <div style="display:flex; align-items:stretch; height:100%;">
                <a href="/USR/Jogos/Loja"
                   style="color:#a89cc8; font-size:13px; font-weight:500; text-decoration:none; padding:0 18px; display:flex; align-items:center; text-transform:uppercase; letter-spacing:0.8px; transition:color 0.2s;"
                   onmouseover="this.style.color='#c9b8ff'; this.style.borderBottom='2px solid #7c4dff';"
                   onmouseout="this.style.color='#a89cc8'; this.style.borderBottom='none';">
                    Loja
                </a>
                <a href="/USR/Biblioteca/Biblioteca"
                   style="color:#a89cc8; font-size:13px; font-weight:500; text-decoration:none; padding:0 18px; display:flex; align-items:center; text-transform:uppercase; letter-spacing:0.8px; transition:color 0.2s;"
                   onmouseover="this.style.color='#c9b8ff'; this.style.borderBottom='2px solid #7c4dff';"
                   onmouseout="this.style.color='#a89cc8'; this.style.borderBottom='none';">
                    Biblioteca
                </a>
            </div>

            <div style="flex:1;"></div>

            <div style="display:flex; align-items:center; gap:12px;">
                @if (Context.Session.GetString("UsuarioNome") != null)
                {
                    <div style="width:36px; height:36px; border-radius:50%; background:#5c2d91; display:flex; align-items:center; justify-content:center; font-size:15px; font-weight:700; color:#e0d0ff; border:2px solid #7c4dff;">
                        @Context.Session.GetString("UsuarioNome")[0]
                    </div>
                    <span style="color:#c9b8ff; font-size:13px; font-weight:500;">
                        @Context.Session.GetString("UsuarioNome")
                    </span>
                    <a href="/USR/Jogos/Carrinho"
                       style="color:#a89cc8; text-decoration:none; font-size:13px; padding:5px 12px; border:1px solid #4a2d7a; border-radius:4px; transition:all 0.2s;"
                       onmouseover="this.style.color='#c9b8ff'; this.style.borderColor='#7c4dff';"
                       onmouseout="this.style.color='#a89cc8'; this.style.borderColor='#4a2d7a';">
                        🛒 Carrinho
                    </a>
                    <a asp-area="" asp-controller="Logins" asp-action="Logout"
                       style="color:#a89cc8; font-size:12px; text-decoration:none; padding:5px 12px; border:1px solid #4a2d7a; border-radius:4px; transition:all 0.2s;"
                       onmouseover="this.style.background='#2d1f4e'; this.style.color='#c9b8ff';"
                       onmouseout="this.style.background='transparent'; this.style.color='#a89cc8';">
                        Sair
                    </a>
                }
                else
                {
                    <a asp-controller="Logins" asp-action="TelaDeLogin"
                       style="background:#5c2d91; color:#e0d0ff; padding:7px 18px; border-radius:4px; font-size:13px; font-weight:600; text-decoration:none; border:1px solid #7c4dff; transition:all 0.2s;"
                       onmouseover="this.style.background='#7c4dff';"
                       onmouseout="this.style.background='#5c2d91';">
                        Entrar
                    </a>
                }
            </div>
        </nav>
    </header>

    <div class="container mt-3">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer style="background:#1a0f2e; border-top:1px solid #3a2060; padding:14px 32px; margin-top:40px;">
        <div class="container" style="color:#6a5a8a; font-size:12px;">
            &copy; 2026 - MVC_GAMEHUB
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>