<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MVC_GAMEHUB</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MVC_GAMEHUB.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav style="background:#1b2838; padding:0 24px; display:flex; align-items:center; height:52px;">

            <a asp-area="" asp-controller="Home" asp-action="Index"
               style="color:#c6d4df; font-size:15px; font-weight:500; margin-right:32px; text-decoration:none;">
                MVC_GAMEHUB
            </a>

            <div style="display:flex; align-items:stretch; height:100%;">
                <a asp-area="" asp-controller="PgPrincipal" asp-action="Loja"
                   style="color:#b8b6b4; font-size:13px; font-weight:500; text-decoration:none; padding:0 16px; display:flex; align-items:center; text-transform:uppercase; letter-spacing:0.8px;">
                    Loja
                </a>
            </div>

            <div style="flex:1;"></div>

            <div style="display:flex; align-items:center; gap:10px;">
                @if (Context.Session.GetString("UsuarioNome") != null)
                {
                    <div style="width:34px; height:34px; border-radius:50%; background:#4b8dca; display:flex; align-items:center; justify-content:center; font-size:14px; font-weight:500; color:#fff;">
                        @Context.Session.GetString("UsuarioNome")[0]
                    </div>
                    <span style="color:#c6d4df; font-size:13px; font-weight:500;">
                        @Context.Session.GetString("UsuarioNome")
                    </span>
                    <a asp-controller="Logins" asp-action="Logout"
                       style="color:#b8b6b4; font-size:12px; text-decoration:none; padding:4px 10px; border:0.5px solid #3a4a5c; border-radius:3px;">
                        Sair
                    </a>
                }
                else
                {
                    <a asp-controller="Logins" asp-action="TelaDeLogin"
                       style="background:#4b8dca; color:#fff; padding:6px 14px; border-radius:3px; font-size:13px; font-weight:500; text-decoration:none;">
                        Entrar
                    </a>
                }
            </div>

        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-bottom footer text-muted">
        <div class="container">
            &copy; 2026 - MVC_GAMEHUB - <a asp-area="" asp-controller="Home"></a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
